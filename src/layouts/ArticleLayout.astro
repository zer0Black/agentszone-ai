---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import TagList from '../components/TagList.astro';
import { getLang, useTranslations, localePath } from '../i18n/utils';

interface Props {
  article: CollectionEntry<'articles'> | CollectionEntry<'articlesEn'>;
  authorName: string;
}

const { article, authorName } = Astro.props;
const { title, description, author, date, tags, original_url } = article.data;
const lang = getLang(Astro.currentLocale);
const t = useTranslations(lang);
const dateLocale = lang === 'en' ? 'en-US' : 'zh-CN';

const formattedDate = new Date(date).toLocaleDateString(dateLocale, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={`${title} | ${t('site.name')}`} description={description}>
  <article class="mx-auto max-w-2xl">
    <header class="mb-12">
      <div class="mb-4 flex flex-wrap items-center gap-2 text-sm text-[var(--color-text-muted)]">
        <a
          href={localePath(lang, `/authors/${author.id}`)}
          class="font-medium text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors"
        >
          {authorName}
        </a>
        <span>/</span>
        <time datetime={date.toISOString()}>{formattedDate}</time>
      </div>
      <h1 class="text-3xl font-bold tracking-tight text-[var(--color-text-primary)] sm:text-4xl">
        {title}
      </h1>
      <div class="mt-4">
        <TagList tags={tags} />
      </div>
      {original_url && (
        <div class="mt-6 glass rounded-xl border-l-2 border-l-[var(--color-accent-start)] px-4 py-2.5 text-sm text-[var(--color-text-secondary)]">
          {t('article.originally')}{' '}
          <a
            href={original_url}
            class="text-[var(--color-primary-600)] dark:text-[var(--color-primary-400)] underline"
            target="_blank"
            rel="noopener noreferrer"
          >
            {new URL(original_url).hostname}
          </a>
        </div>
      )}
    </header>
    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>
