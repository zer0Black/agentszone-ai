---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CommunityCard from '../../components/CommunityCard.astro';

const allAuthors = await getCollection('authors');
const communityMembers = allAuthors
  .filter((a) => !!a.data.influence)
  .sort((a, b) => {
    const order = { core: 0, active: 1, contributor: 2 };
    const aOrder = order[a.data.influence ?? 'contributor'] ?? 2;
    const bOrder = order[b.data.influence ?? 'contributor'] ?? 2;
    return aOrder - bOrder;
  });
---

<BaseLayout
  title="社区成员 | Agents 特区"
  description="认识在 AI Coding 群里活跃讨论的一线实践者。"
>
  <h1 class="text-3xl font-bold tracking-tight text-[var(--color-text-primary)] sm:text-4xl">
    社区成员
  </h1>
  <p class="mt-2 mb-10 text-[var(--color-text-muted)]">
    在 AI Coding 群里活跃讨论的一线实践者。画像基于群讨论记录自动提取。
  </p>
  <div class="grid gap-4" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr))">
    {communityMembers.map((member) => <CommunityCard member={member} />)}
  </div>
</BaseLayout>
