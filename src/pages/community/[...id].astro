---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { localePath } from '../../i18n/utils';

export async function getStaticPaths() {
  const authors = await getCollection('authors');
  const community = authors.filter((a) => !!a.data.influence);
  return community.map((member) => ({
    params: { id: member.id },
    props: { member },
  }));
}

const { member } = Astro.props;
const { name, bio, avatar, tags, influence, since } = member.data;
const { Content } = await render(member);

// Check if this person also has articles
const articles = await getCollection('articles', ({ data }) => {
  return !data.draft;
});
const authorArticles = articles
  .filter((a) => a.data.author.id === member.id)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

// Check if they have an author page (self is author-role, or another entry with same name is)
const allAuthors = await getCollection('authors');
const selfIsAuthor = member.data.role !== 'community';
const otherAuthor = allAuthors.find((a) => a.id !== member.id && a.data.role !== 'community' && a.data.name === name);
const authorProfileId = selfIsAuthor ? member.id : otherAuthor?.id;
const hasAuthorProfile = !!authorProfileId;

const influenceLabels: Record<string, string> = {
  core: '核心成员',
  active: '活跃成员',
  contributor: '贡献者',
};
---

<BaseLayout
  title={`${name} | 社区成员 | Agents 特区`}
  description={bio}
>
  <div class="mb-6">
    <a href={localePath('zh', '/community')} class="text-sm text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors">
      ← 社区成员
    </a>
  </div>

  <div class="flex items-start gap-6 mb-8">
    {avatar ? (
      <img src={avatar} alt={name} class="h-20 w-20 rounded-full object-cover ring-2 ring-[var(--color-surface-border)]" />
    ) : (
      <div class="flex h-20 w-20 items-center justify-center rounded-full bg-gradient-to-br from-[var(--color-primary-400)] to-purple-500 text-white font-bold text-2xl ring-2 ring-[var(--color-surface-border)]">
        {name.charAt(0).toUpperCase()}
      </div>
    )}
    <div>
      <h1 class="text-3xl font-bold text-[var(--color-text-primary)]">{name}</h1>
      <p class="mt-1 text-[var(--color-text-muted)]">{bio}</p>
      <div class="mt-3 flex flex-wrap items-center gap-3">
        {influence && (
          <span class="inline-block rounded-full bg-amber-500/15 px-3 py-1 text-xs font-medium text-amber-400">
            {influenceLabels[influence] ?? influence}
          </span>
        )}
        {since && (
          <span class="text-xs text-[var(--color-text-muted)]">
            加入于 {since}
          </span>
        )}
      </div>
    </div>
  </div>

  {tags && tags.length > 0 && (
    <div class="flex flex-wrap gap-2 mb-8">
      {tags.map((tag: string) => (
        <a
          href={localePath('zh', `/tags/${tag}`)}
          class="inline-block rounded-full bg-[var(--color-primary-500)]/15 px-3 py-1 text-xs font-medium text-[var(--color-primary-300)] hover:bg-[var(--color-primary-500)]/25 transition-all"
        >
          #{tag}
        </a>
      ))}
    </div>
  )}

  <div class="prose prose-invert max-w-none mb-10">
    <h2 class="text-lg font-semibold text-[var(--color-text-primary)] mb-4">社区画像</h2>
    <p class="text-sm text-[var(--color-text-muted)] mb-4">基于群讨论记录自动提取，不代表本人自述。</p>
    <div class="text-[var(--color-text-secondary)] leading-relaxed">
      <Content />
    </div>
  </div>

  {hasAuthorProfile && (
    <div class="mb-8 rounded-lg border border-[var(--color-surface-border)] p-4">
      <p class="text-sm text-[var(--color-text-muted)]">
        📝 此成员也是文章作者 →
        <a href={localePath('zh', `/authors/${authorProfileId}`)} class="text-[var(--color-accent)] hover:underline">
          查看作者页
        </a>
      </p>
    </div>
  )}

  {authorArticles.length > 0 && (
    <div>
      <h2 class="text-lg font-semibold text-[var(--color-text-primary)] mb-4">相关文章</h2>
      <div class="space-y-3">
        {authorArticles.map((article) => (
          <a href={localePath('zh', `/articles/${article.id}`)} class="block p-3 rounded-lg hover:bg-[var(--color-surface-raised)] transition-colors">
            <p class="font-medium text-[var(--color-text-primary)]">{article.data.title}</p>
            <p class="text-sm text-[var(--color-text-muted)] mt-1">{article.data.description}</p>
          </a>
        ))}
      </div>
    </div>
  )}
</BaseLayout>
