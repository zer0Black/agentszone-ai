---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ArticleCard from '../../../components/ArticleCard.astro';
import { useTranslations } from '../../../i18n/utils';

export async function getStaticPaths() {
  const articles = await getCollection('articlesEn');
  const authors = await getCollection('authors');
  const authorMap = new Map(authors.map((a) => [a.id, a.data.name]));

  const tags = new Set<string>();
  for (const article of articles) {
    for (const tag of article.data.tags) {
      tags.add(tag);
    }
  }

  return [...tags].map((tag) => ({
    params: { tag },
    props: {
      tag,
      articles: articles
        .filter((article) => article.data.tags.includes(tag))
        .sort(
          (a, b) =>
            new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
        ),
      authorMap,
    },
  }));
}

const t = useTranslations('en');
const { tag, articles, authorMap } = Astro.props;
---

<BaseLayout
  title={`${tag} | ${t('site.name')}`}
  description={`Articles tagged "${tag}".`}
>
  <h1 class="text-3xl font-bold tracking-tight text-[var(--color-text-primary)] sm:text-4xl">
    &ldquo;{tag}&rdquo; {t('tags.related')}
  </h1>
  <p class="mt-2 mb-10 text-[var(--color-text-muted)]">{t('tags.browse')}</p>
  <div class="grid gap-4 sm:grid-cols-2">
    {articles.map((article) => (
      <ArticleCard
        article={article}
        authorName={authorMap.get(article.data.author.id) ?? 'Unknown'}
      />
    ))}
  </div>
</BaseLayout>
