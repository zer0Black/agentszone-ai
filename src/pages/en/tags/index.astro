---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { useTranslations } from '../../../i18n/utils';

const t = useTranslations('en');

const articles = await getCollection('articlesEn', ({ data }) => {
  return import.meta.env.PROD ? !data.draft : true;
});

const tagCounts = new Map<string, number>();
for (const article of articles) {
  for (const tag of article.data.tags) {
    tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
  }
}

const sortedTags = [...tagCounts.entries()].sort((a, b) =>
  a[0].localeCompare(b[0])
);
---

<BaseLayout
  title={`${t('tags.title')} | ${t('site.name')}`}
  description={t('tags.desc')}
>
  <h1 class="text-3xl font-bold tracking-tight text-[var(--color-text-primary)] sm:text-4xl">
    {t('tags.title')}
  </h1>
  <p class="mt-2 mb-10 text-[var(--color-text-muted)]">{t('tags.desc')}</p>
  <div class="flex flex-wrap gap-3">
    {sortedTags.map(([tag, count]) => (
      <a
        href={`/en/tags/${tag}`}
        class="group inline-flex items-center gap-2 rounded-full border border-[var(--color-surface-border)] bg-[var(--color-surface-alt)] px-4 py-2 text-sm font-medium text-[var(--color-text-primary)] hover:border-[var(--color-primary-500)]/50 hover:text-[var(--color-primary-400)] hover:shadow-sm transition-all"
      >
        {tag}
        <span class="text-xs text-[var(--color-text-muted)] group-hover:text-[var(--color-primary-500)] transition-colors">
          {count}
        </span>
      </a>
    ))}
  </div>
  {sortedTags.length === 0 && (
    <p class="text-[var(--color-text-muted)] text-sm">
      No English articles yet. Check the{' '}
      <a href="/tags" class="text-[var(--color-primary-600)] dark:text-[var(--color-primary-400)] underline">Chinese version</a>.
    </p>
  )}
</BaseLayout>
