---
import { getLang, useTranslations, localePath } from '../i18n/utils';

const lang = getLang(Astro.currentLocale);
const t = useTranslations(lang);
const year = new Date().getFullYear();
const siteName = lang === 'en' ? 'AgentsZone' : 'Agents 特区';
---

<footer class="bg-[var(--color-surface)]">
  <div class="gradient-line"></div>
  <div class="mx-auto max-w-5xl px-6 sm:px-8 py-16">
    <div class="flex flex-col gap-8 sm:flex-row sm:justify-between">
      <div class="max-w-xs">
        <div class="flex items-center gap-2.5">
          <div class="flex h-7 w-7 items-center justify-center rounded-md bg-gradient-to-br from-[var(--color-primary-500)] to-purple-500 text-xs font-bold text-white shadow-md shadow-[var(--color-primary-500)]/25">
            A
          </div>
          <span class="text-lg font-bold tracking-tight text-[var(--color-text-primary)]">
            Agents{lang !== 'en' && ' '}<span class="text-gradient">{lang === 'en' ? 'Zone' : '特区'}</span>
          </span>
        </div>
        <p class="mt-3 text-sm text-[var(--color-text-muted)] leading-relaxed">
          {t('footer.desc')}
        </p>
      </div>
      <div class="flex gap-8 text-sm">
        <div class="flex flex-col gap-3">
          <a href={localePath(lang, '/articles')} class="text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)] transition-colors">{t('nav.articles')}</a>
          <a href={localePath(lang, '/authors')} class="text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)] transition-colors">{t('nav.authors')}</a>
          <a href={localePath(lang, '/tags')} class="text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)] transition-colors">{t('nav.tags')}</a>
          <a href={localePath(lang, '/events')} class="text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)] transition-colors">{t('nav.events')}</a>
        </div>
        <div class="flex flex-col gap-3">
          <a href="/rss.xml" class="text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)] transition-colors">RSS</a>
          <a
            href="https://github.com/lipingtababa/agentszone-ai"
            class="text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)] transition-colors"
            target="_blank"
            rel="noopener noreferrer"
          >
            {t('footer.contribute')} <span class="inline-block translate-y-[-1px] text-[10px] opacity-50">&#8599;</span>
          </a>
        </div>
      </div>
    </div>
    <div class="mt-12 border-t border-[var(--color-surface-border)] pt-6">
      <p class="text-xs text-[var(--color-text-muted)]">
        &copy; {year} {siteName}
      </p>
    </div>
  </div>
</footer>
