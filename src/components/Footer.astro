---
const year = new Date().getFullYear();
---

<footer class="border-t border-[var(--color-surface-border)] bg-[var(--color-surface)]">
  <div class="mx-auto max-w-4xl px-6 py-12">
    <div class="flex flex-col gap-8 sm:flex-row sm:justify-between">
      <div class="max-w-xs">
        <a href="/" class="font-serif text-lg font-semibold text-[var(--color-text-primary)]">
          Agents 特区
        </a>
        <p class="mt-2 text-sm text-[var(--color-text-muted)] leading-relaxed">
          一线实践者的AI agent管理经验，从个人探索到组织级实践。
        </p>
      </div>
      <div class="flex gap-8 text-sm">
        <div class="flex flex-col gap-2">
          <a href="/articles" class="text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors">文章</a>
          <a href="/authors" class="text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors">作者</a>
          <a href="/tags" class="text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors">话题</a>
          <a href="/events" class="text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors">活动</a>
        </div>
        <div class="flex flex-col gap-2">
          <a href="/rss.xml" class="text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors">RSS</a>
          <a
            href="https://github.com/lipingtababa/agentszone-ai"
            class="text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors"
            target="_blank"
            rel="noopener noreferrer"
          >
            投稿 ↗
          </a>
        </div>
      </div>
    </div>
    <div class="mt-8 pt-6 border-t border-[var(--color-surface-border)]">
      <p class="text-xs text-[var(--color-text-muted)]">
        &copy; {year} Agents 特区
      </p>
    </div>
  </div>
</footer>
