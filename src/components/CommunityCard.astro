---
import type { CollectionEntry } from 'astro:content';
import { getLang, localePath } from '../i18n/utils';

interface Props {
  member: CollectionEntry<'authors'> | CollectionEntry<'authorsEn'>;
}

const { member } = Astro.props;
const { name, bio, avatar, tags, influence } = member.data;
const lang = getLang(Astro.currentLocale);

const influenceColors: Record<string, { bg: string; text: string; label: string; labelEn: string }> = {
  core: { bg: 'bg-amber-500/15', text: 'text-amber-400', label: '核心', labelEn: 'Core' },
  active: { bg: 'bg-emerald-500/15', text: 'text-emerald-400', label: '活跃', labelEn: 'Active' },
  contributor: { bg: 'bg-slate-500/15', text: 'text-slate-400', label: '贡献者', labelEn: 'Contributor' },
};

const badge = influence ? influenceColors[influence] : null;
---

<a
  href={localePath(lang, `/community/${member.id}`)}
  class="group flex flex-col rounded-xl border border-[var(--color-surface-border)] p-5 transition-all glow-hover"
>
  <div class="flex items-center gap-4 mb-3">
    {avatar ? (
      <img
        src={avatar}
        alt={name}
        class="h-12 w-12 rounded-full object-cover ring-2 ring-[var(--color-surface-border)] group-hover:ring-[var(--color-primary-400)] transition-all"
      />
    ) : (
      <div class="flex h-12 w-12 items-center justify-center rounded-full bg-gradient-to-br from-[var(--color-primary-400)] to-purple-500 ring-2 ring-[var(--color-surface-border)] group-hover:ring-[var(--color-primary-400)] text-white font-semibold text-sm transition-all">
        {name.charAt(0).toUpperCase()}
      </div>
    )}
    <div class="min-w-0 flex-1">
      <p class="font-medium text-[var(--color-text-primary)]">
        <span class="hover-text-gradient">{name}</span>
      </p>
      {badge && (
        <span class={`inline-block mt-0.5 rounded-full px-2 py-0.5 text-[10px] font-medium ${badge.bg} ${badge.text}`}>
          {lang === 'en' ? badge.labelEn : badge.label}
        </span>
      )}
    </div>
  </div>
  <p class="text-sm text-[var(--color-text-muted)] line-clamp-2 mb-3">{bio}</p>
  {tags && tags.length > 0 && (
    <div class="flex flex-wrap gap-1.5 mt-auto">
      {tags.map((tag: string) => (
        <span class="inline-block rounded-full bg-[var(--color-primary-500)]/10 px-2 py-0.5 text-[10px] text-[var(--color-primary-300)]">
          {tag}
        </span>
      ))}
    </div>
  )}
</a>
