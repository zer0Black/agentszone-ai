---
import { getLang, localePath } from '../i18n/utils';

interface Props {
  tags: string[];
}

const { tags } = Astro.props;
const lang = getLang(Astro.currentLocale);
---

<div class="flex flex-wrap gap-2">
  {tags.map((tag) => (
    <a
      href={localePath(lang, `/tags/${tag}`)}
      class="inline-block rounded-full bg-[var(--color-primary-500)]/15 px-2.5 py-0.5 text-xs font-medium text-[var(--color-primary-300)] hover:bg-[var(--color-primary-500)]/25 transition-all"
    >
      {tag}
    </a>
  ))}
</div>
