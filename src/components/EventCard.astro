---
import type { CollectionEntry } from 'astro:content';
import TagList from './TagList.astro';
import { getLang, useTranslations, localePath } from '../i18n/utils';

interface Props {
  event: CollectionEntry<'events'>;
}

const { event } = Astro.props;
const { number, title, description, date, speakers, poster, tags } = event.data;
const lang = getLang(Astro.currentLocale);
const t = useTranslations(lang);
const dateLocale = lang === 'en' ? 'en-US' : 'zh-CN';

const formattedDate = new Date(date).toLocaleDateString(dateLocale, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const eventHref = localePath(lang, `/events/${event.id}`);
const episodeLabel = t('event.episode', { n: number });
---

<article class="group rounded-xl border border-[var(--color-surface-border)] overflow-hidden glow-hover transition-all">
  <a href={eventHref} class="block">
    {poster ? (
      <div class="aspect-[2/1] overflow-hidden">
        <img
          src={poster}
          alt={title}
          class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
          loading="lazy"
        />
      </div>
    ) : (
      <div class="aspect-[2/1] flex items-center justify-center bg-gradient-to-br from-[var(--color-primary-600)] via-[var(--color-primary-700)] to-purple-800">
        <span class="text-5xl font-bold text-white/30">#{number}</span>
      </div>
    )}
  </a>
  <div class="px-5 py-4">
    <div class="mb-2 flex items-center gap-2 text-xs text-[var(--color-text-muted)]">
      <span class="inline-block rounded-full bg-gradient-to-r from-[var(--color-primary-500)] to-purple-500 px-2.5 py-0.5 text-xs font-medium text-white">
        {episodeLabel}
      </span>
      <time datetime={date.toISOString()}>{formattedDate}</time>
    </div>
    <a href={eventHref} class="block">
      <h2 class="text-lg font-semibold text-[var(--color-text-primary)] transition-all">
        <span class="hover-text-gradient">{title}</span>
      </h2>
    </a>
    <p class="mt-1.5 text-sm text-[var(--color-text-secondary)] leading-relaxed line-clamp-2">{description}</p>
    {speakers && speakers.length > 0 && (
      <div class="mt-2 flex flex-wrap gap-1.5">
        {speakers.map((speaker) => (
          <span class="inline-block rounded-full border border-[var(--color-surface-border)] bg-[var(--color-surface-alt)] px-2.5 py-0.5 text-xs text-[var(--color-text-muted)]">
            {speaker}
          </span>
        ))}
      </div>
    )}
    <div class="mt-3">
      <TagList tags={tags} />
    </div>
  </div>
</article>
