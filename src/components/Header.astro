---
import ThemeToggle from './ThemeToggle.astro';
import { getLang, useTranslations, localePath, alternatePath } from '../i18n/utils';

const lang = getLang(Astro.currentLocale);
const t = useTranslations(lang);
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: localePath(lang, '/articles'), label: t('nav.articles') },
  { href: localePath(lang, '/authors'), label: t('nav.authors') },
  { href: localePath(lang, '/discussions'), label: t('nav.discussions') },
  { href: localePath(lang, '/events'), label: t('nav.events') },
];

const homeHref = localePath(lang, '/');
const switchHref = alternatePath(currentPath, lang);
const switchLabel = t('lang.switch');
---


<header class="border-b border-[var(--color-surface-border)] bg-[var(--color-surface)]">
  <nav class="mx-auto flex max-w-4xl items-center justify-between px-6 py-5">
    <a href={homeHref} class="inline-flex items-center gap-2 font-serif text-xl font-semibold tracking-tight text-[var(--color-text-primary)] hover:text-[var(--color-accent)] transition-colors">
      <div class="flex h-7 w-7 items-center justify-center rounded-md bg-gradient-to-br from-[var(--color-primary-500)] to-purple-500 text-xs font-bold text-white shadow-md shadow-[var(--color-primary-500)]/25">
        A
      </div>
      <span class="text-lg font-bold tracking-tight text-[var(--color-text-primary)]">
        Agents{lang !== 'en' && ' '}<span class="text-gradient">{lang === 'en' ? 'Zone' : '特区'}</span>
      </span>
    </a>
    <!-- Desktop nav -->
    <div class="hidden sm:flex items-center gap-6">
      {navLinks.map(({ href, label, external }) => (
        <a
          href={href}
          {...(external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
          class:list={[
            'text-sm transition-colors',
            !external && currentPath.startsWith(href)
              ? 'text-[var(--color-text-primary)] font-medium'
              : 'text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)]',
          ]}
        >
          {label}
          {external && <span class="ml-0.5 text-xs opacity-50">↗</span>}
        </a>
      ))}
      <a
        href={switchHref}
        class="ml-1 flex items-center gap-1.5 rounded-md border border-[var(--color-surface-border)] px-2.5 py-1.5 text-xs font-medium text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)] hover:border-[var(--color-text-muted)]/40 transition-colors"
        title={switchLabel}
      >
        <svg class="h-3.5 w-3.5 opacity-70" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-1.605.42-3.113 1.157-4.418" />
        </svg>
        {switchLabel}
      </a>
      <div class="ml-2">
        <ThemeToggle />
      </div>
    </div>

    <!-- Mobile: Theme toggle + hamburger -->
    <div class="flex items-center gap-3 sm:hidden">
      <ThemeToggle />
      <button
        id="mobile-menu-toggle"
        type="button"
        class="p-2 text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)] transition-colors"
        aria-label="Toggle menu"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile nav -->
  <div id="mobile-menu" class="hidden sm:hidden border-t border-[var(--color-surface-border)] px-6 pb-4">
    <div class="flex flex-col gap-1 pt-2">
      {navLinks.map(({ href, label, external }) => (
        <a
          href={href}
          {...(external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
          class:list={[
            'py-2 text-sm transition-colors',
            !external && currentPath.startsWith(href)
              ? 'text-[var(--color-text-primary)] font-medium'
              : 'text-[var(--color-text-muted)]',
          ]}
        >
          {label}
          {external && <span class="ml-0.5 text-xs opacity-50">↗</span>}
        </a>
      ))}
      <a
        href={switchHref}
        class="flex items-center gap-1.5 rounded-md px-3 py-2 text-sm font-medium text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)] hover:bg-[var(--color-surface-elevated)] transition-colors"
      >
        <svg class="h-4 w-4 opacity-60" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-1.605.42-3.113 1.157-4.418" />
        </svg>
        {switchLabel}
      </a>
      <div class="px-3 pt-2">
        <ThemeToggle />
      </div>
    </div>
  </div>
</header>

<script>
  document.getElementById('mobile-menu-toggle')?.addEventListener('click', () => {
    const menu = document.getElementById('mobile-menu');
    menu?.classList.toggle('hidden');
  });
</script>
