---
import type { CollectionEntry } from 'astro:content';
import { getLang, localePath } from '../i18n/utils';

interface Props {
  author: CollectionEntry<'authors'> | CollectionEntry<'authorsEn'>;
}

const { author } = Astro.props;
const { name, bio, avatar } = author.data;
const lang = getLang(Astro.currentLocale);
const href = localePath(lang, `/authors/${author.id}`);
---

<a
  href={href}
  class="group flex items-center gap-4 rounded-xl border border-[var(--color-surface-border)] p-4 transition-all glow-hover"
>
  {avatar ? (
    <img
      src={avatar}
      alt={name}
      class="h-12 w-12 rounded-full object-cover ring-2 ring-[var(--color-surface-border)] group-hover:ring-[var(--color-primary-400)] group-hover:shadow-md group-hover:shadow-[var(--color-primary-500)]/20 transition-all"
    />
  ) : (
    <div class="flex h-12 w-12 items-center justify-center rounded-full bg-gradient-to-br from-[var(--color-primary-400)] to-purple-500 ring-2 ring-[var(--color-surface-border)] group-hover:ring-[var(--color-primary-400)] group-hover:shadow-md group-hover:shadow-[var(--color-primary-500)]/20 text-white font-semibold text-sm transition-all">
      {name.charAt(0).toUpperCase()}
    </div>
  )}
  <div class="min-w-0 flex-1">
    <p class="font-medium text-[var(--color-text-primary)]">
      <span class="hover-text-gradient">{name}</span>
    </p>
    <p class="text-sm text-[var(--color-text-muted)] line-clamp-1">{bio}</p>
  </div>
  <svg class="h-4 w-4 text-[var(--color-text-muted)] opacity-0 -translate-x-1 group-hover:opacity-100 group-hover:translate-x-0 transition-all" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
  </svg>
</a>
